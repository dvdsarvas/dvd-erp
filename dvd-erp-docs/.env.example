# .env.example
# Kopiraj u .env.local za lokalni razvoj
# NIKAD ne commitati .env.local u git

# ============================================================
# LOKALNI RAZVOJ
# ============================================================

# Preskoči subdomain resolve i koristi direktno
VITE_DEV_MODE=true

# DVD Sarvaš — lokalni razvoj
VITE_SUPABASE_URL=https://PROJEKT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================================
# PRODUKCIJA (Cloudflare Pages environment variables)
# ============================================================

# Isključi dev mode u produkciji
# VITE_DEV_MODE=false

# Meta-registry projekt (centralni router za subdomene)
# VITE_REGISTRY_URL=https://REGISTRY_PROJEKT_ID.supabase.co
# VITE_REGISTRY_ANON_KEY=eyJ...

# ============================================================
# SUPABASE EDGE FUNCTIONS (postavljaju se u Supabase Dashboard)
# Dashboard → Project Settings → Edge Functions → Secrets
# ============================================================
# RESEND_API_KEY=re_...
# (SUPABASE_URL i SUPABASE_SERVICE_ROLE_KEY su automatski dostupni)
