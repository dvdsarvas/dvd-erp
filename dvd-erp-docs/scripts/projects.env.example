PROJECTS=(
  "DVD Sarvaš|postgresql://postgres:LOZINKA@db.PROJEKT_ID.supabase.co:5432/postgres"
  # "DVD Antunovac|postgresql://postgres:LOZINKA@db.DRUGI_ID.supabase.co:5432/postgres"
  # "DVD Novi|postgresql://postgres:LOZINKA@db.TRECI_ID.supabase.co:5432/postgres"
)

# Format svake stavke:
# "Naziv DVD-a|postgresql://postgres:lozinka@db.projekt_id.supabase.co:5432/postgres"
#
# Lozinka i projekt ID se nalaze u:
# Supabase Dashboard → Project Settings → Database → Connection string (URI)
